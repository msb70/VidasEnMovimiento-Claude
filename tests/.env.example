# Copia este archivo a .env y rellena los valores.
# .env NUNCA se commitea (está en .gitignore).

# Público (se puede compartir)
SUPABASE_URL=https://izcqcnunryhntojhxywu.supabase.co
SUPABASE_ANON_KEY=sb_publishable__LIveg146Avk4WSUp3WjWA_G55IhbYa

# SECRETO — Supabase Dashboard -> Project Settings -> API -> service_role.
# Solo se usa en el setup para crear/garantizar los usuarios de prueba.
# NO lo subas a git. En CI va como secret del repositorio.
